<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <receiver
            android:name=".cab.CabSmokeReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.nova.luna.debug.ACTION_RUN_CAB_SMOKE" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".brain.BrainSmokeReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.nova.luna.debug.ACTION_RUN_BRAIN_SMOKE" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".smoke.CommandSmokeReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.nova.luna.debug.ACTION_RUN_COMMAND_SMOKE" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
