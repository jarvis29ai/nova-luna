<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <queries>
        <!-- Content Creation Apps -->
        <package android:name="com.canva.editor" />
        <package android:name="com.openai.chatgpt" />
        <package android:name="com.google.android.apps.bard" /> <!-- Gemini -->
        <package android:name="com.anthropic.claude" />
        <package android:name="com.lemon.lvoverseas" /> <!-- CapCut -->
        <package android:name="com.google.android.apps.docs.editors.docs" />
        <package android:name="com.google.android.apps.docs.editors.sheets" />
        <package android:name="com.microsoft.office.powerpoint" />
        <package android:name="com.microsoft.office.word" />
        <package android:name="com.microsoft.office.excel" />

        <!-- Phone / assistant / navigation apps -->
        <package android:name="com.android.camera" />
        <package android:name="com.google.android.GoogleCamera" />
        <package android:name="com.sec.android.app.camera" />
        <package android:name="com.android.settings" />
        <package android:name="com.google.android.youtube" />
        <package android:name="com.android.chrome" />
        <package android:name="org.mozilla.firefox" />
        <package android:name="com.microsoft.emmx" />
        <package android:name="com.google.android.dialer" />
        <package android:name="com.android.dialer" />
        <package android:name="com.samsung.android.dialer" />
        <package android:name="com.google.android.apps.messaging" />
        <package android:name="com.android.messaging" />
        <package android:name="com.samsung.android.messaging" />
        <package android:name="com.google.android.apps.maps" />

        <!-- Cab providers -->
        <package android:name="com.ubercab" />
        <package android:name="com.olacabs.customer" />
        <package android:name="com.rapido.passenger" />
        <package android:name="sinet.startup.inDriver" />
        <package android:name="sinet.startup.indriver" />
        <package android:name="com.indriver" />

        <!-- Food providers -->
        <package android:name="in.swiggy.android" />
        <package android:name="com.application.zomato" />
        <package android:name="com.toings.app" />
        <package android:name="com.toings.android" />
        <package android:name="com.toings.food" />

        <!-- Grocery providers -->
        <package android:name="com.grofers.customerapp" />
        <package android:name="com.zeptoconsumerapp" />
        <package android:name="com.zepto" />
        <package android:name="com.jpl.jiomart" />
        <package android:name="in.swiggy.android.instamart" />
        <package android:name="com.bigbasket.mobileapp" />
        <package android:name="com.bigbasket" />

        <!-- Music providers -->
        <package android:name="com.spotify.music" />
        <package android:name="com.google.android.apps.youtube.music" />
        <package android:name="com.apple.android.music" />
        <package android:name="com.jio.media.jiobeats" />
        <package android:name="com.bsb.hike" />
        <package android:name="com.gaana" />
        <package android:name="com.android.music" />
        <package android:name="com.google.android.apps.photos" />

        <!-- Shopping providers -->
        <package android:name="com.amazon.mShop.android.shopping" />
        <package android:name="com.flipkart.android" />
        <package android:name="com.croma.deals" />
        <package android:name="com.reliance.digital" />

        <!-- Communication providers -->
        <package android:name="com.google.android.gm" />
        <package android:name="com.whatsapp" />
        <package android:name="org.telegram.messenger" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.NovaLuna">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false" />

        <activity
            android:name=".history.CommandHistoryActivity"
            android:exported="false" />

        <service
            android:name=".service.VoiceCommandService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <service
            android:name=".service.NovaAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Safe by default: keep disabled until you deliberately opt into auto-start. -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="false"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
