<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.NovaLuna" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/nova_primary</item>
        <item name="colorOnPrimary">@color/nova_on_primary</item>
        <item name="colorSecondary">@color/nova_secondary</item>
        <item name="colorOnSecondary">@color/nova_on_secondary</item>
        <item name="colorTertiary">@color/nova_tertiary</item>
        <item name="android:colorBackground">@color/nova_background</item>
        <item name="colorOnBackground">@color/nova_on_background</item>
        <item name="colorSurface">@color/nova_surface</item>
        <item name="colorOnSurface">@color/nova_on_surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/nova_background</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/nova_background</item>
        
        <item name="android:windowBackground">@drawable/bg_futuristic_main</item>
    </style>

    <style name="NovaCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/nova_card_dark</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <style name="NovaButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_gradient_button</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/nova_white</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
